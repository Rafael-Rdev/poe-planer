/**
 * Mock-Datenbank für PoE 2 Ausrüstungsgegenstände.
 *
 * Jedes Item hat:
 * - id: Eindeutige Kennung
 * - nameDe: Deutscher Name
 * - nameEn: Englischer Name
 * - type: Gegenstandstyp (bestimmt den Slot)
 * - stats: Array von Modifikatoren ({ name, value })
 *
 * Datenstruktur: Record<string, Item> für O(1) Lookups
 */
export interface ItemStat {
  name: string;
  value: number;
}

export interface Item {
  id: string;
  nameDe: string;
  nameEn: string;
  type: string;
  stats: ItemStat[];
}

/**
 * Alle verfügbaren Items als Record (O(1) Lookup via ID).
