/**
 * Erweiterte Gemmen-Datenbank für das interaktive Gemmen-System.
 *
 * Jede Gemme hat:
 * - id: Eindeutige Kennung
 * - nameEn: Englischer Name (für Parser-Matching)
 * - nameDe: Deutscher Name (PS5-Terminologie)
 * - type: "active" (Fertigkeit) oder "support" (Unterstützung)
 * - color: "red" | "green" | "blue" (entspricht PoE-Sockelfarben)
 * - effect: Deutsche Effekt-Beschreibung
 * - description: Kurze deutsche Beschreibung
 *
 * Datenstruktur: Record<string, Gem> für O(1) Lookups
 */

export type GemColor = "red" | "green" | "blue";
export type GemType = "active" | "support";

export interface Gem {
  id: string;
  nameEn: string;
  nameDe: string;
  type: GemType;
  color: GemColor;
  effect: string;
  description: string;
}

